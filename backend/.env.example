# Google AI
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/eventos

# Google Custom Search (for Context + Sponsor agents)
GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Google OAuth (for user login + Gmail email sending)
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret_here
JWT_SECRET=your_random_jwt_secret_here
FRONTEND_URL=http://localhost:8080

# Discord (for Discord sub-agent)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Vultr GPU Instance (for Stable Diffusion + CogVideoX)
VULTR_GPU_ENDPOINT=http://your-vultr-gpu-ip:8000
